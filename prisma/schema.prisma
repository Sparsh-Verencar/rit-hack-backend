datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

model User {
  id         String   @id // Clerk ID
  email      String   @unique
  name       String?
  created_at DateTime @default(now())

  projects Project[]

  @@map("users") // Keeps your actual Postgres table named "users"
}

model Project {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String
  name            String
  original_r2_key String
  row_count       Int
  col_count       Int
  columns         Json     @default("{}") // Postgres JSONB
  created_at      DateTime @default(now())

  user     User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  versions ProjectVersion[]

  @@index([user_id])
  @@map("projects")
}

model ProjectVersion {
  id          String   @id @default(uuid()) @db.Uuid
  project_id  String   @db.Uuid
  version_num Int      @default(0)
  r2_key      String
  prompt      String?
  summary     String?
  ops_log     Json?    // Array of agent operations
  row_count   Int
  col_count   Int
  status      String   @default("pending") // pending, processing, done, failed
  created_at  DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([status])
  @@map("project_versions")
}